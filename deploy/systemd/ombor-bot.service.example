[Unit]
Description=Ombor Telegram Bot
After=network.target

[Service]
Type=simple
User=omborbot
Group=omborbot
WorkingDirectory=/opt/ombor_bot
EnvironmentFile=/opt/ombor_bot/.env
ExecStart=/opt/ombor_bot/.venv/bin/python -m app.main
Restart=always
RestartSec=5
KillSignal=SIGINT
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target

BOT_TOKEN=your_telegram_bot_token_here
ADMIN_IDS=123456789
DATABASE_URL=sqlite+aiosqlite:///data/ombor_bot.sqlite3

# Option 1: Google Apps Script Web App (recommended)
GOOGLE_SCRIPT_WEBAPP_URL=
GOOGLE_SCRIPT_SECRET=

# Option 2: Service Account (legacy)
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/service_account.json

# Bot run mode: polling or webhook
BOT_MODE=polling

# Webhook settings (required when BOT_MODE=webhook)
WEBHOOK_BASE_URL=
WEBHOOK_SECRET_PATH=
WEBAPP_HOST=127.0.0.1
WEBAPP_PORT=8080
